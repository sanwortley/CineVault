{
  "name": "cinevault",
  "version": "1.0.0",
  "description": "Personal movie library manager - Web PWA",
  "scripts": {
    "vite": "vite",
    "web": "vite",
    "backend": "tsx backend/server.ts",
    "web:dev": "node kill_ports.js && concurrently \"npm run backend\" \"npm run vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "tsx backend/server.ts",
    "tsc:check": "tsc --noEmit",
    "tsc:check:backend": "tsc --noEmit --project backend/tsconfig.json",
    "typecheck": "npm run tsc:check && npm run tsc:check:backend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "axios": "^1.6.0",
    "chardet": "^2.1.1",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.3.0",
    "express": "5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^10.16.0",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.292.0",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "sqlite3": "^5.1.7",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^6.0.3",
    "vite": "^4.4.0"
  }
