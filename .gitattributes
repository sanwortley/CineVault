# Handle line endings automatically for files detected as text 
# and truly force them to be normalized (LF) on checkin.
* text=auto eol=lf
*.md text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
