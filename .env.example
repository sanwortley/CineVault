# CineVault Environment Variables Template
# Copy these to your Railway Project Settings

# 1. Admin Email (for admin features)
ADMIN_EMAIL=tu_email_admin@gmail.com
VITE_ADMIN_EMAIL=tu_email_admin@gmail.com

# 2. TMDB API (Get from themoviedb.org)
TMDB_API_KEY=tu_api_key_aqui
VITE_TMDB_API_KEY=tu_api_key_aqui

# 2. Supabase (Get from supabase.com project settings)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui

# 3. Google OAuth (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret
VITE_GOOGLE_API_KEY=tu_google_api_key

# 4. Railway Specifics
# El puerto lo asigna Railway automáticamente (process.env.PORT)
NODE_ENV=production

# 5. Persistent Storage (Optional but recommended)
# Si creas un Volume en Railway, apunta esta ruta a la montura del volumen
# ej: /data/drive-token.json
DRIVE_TOKEN_PATH=./drive-token.json
